import React from 'react';
import { SafeAreaViewProvider } from 'react-native-safe-area-context';
import styled, { ThemeProvider } from 'styled-components/native';

const theme = {
  colors: {
    primary: '#059669',
    text: '#1f2937',
    background: '#ffffff',
  },
  spacing: {
    small: '8px',
    medium: '16px',
    large: '24px',
  }
};

const Typography = {
  H1: styled.Text`
    font-size: 32px;
    font-weight: bold;
    color: ${props => props.theme.colors.text};
  `,
  Body: styled.Text`
    font-size: 16px;
    color: ${props => props.theme.colors.text};
  `,
};

const Card = styled.View`
  background-color: #f3f4f6;
  border-radius: 12px;
  padding: ${props => props.$spacing || '16px'};
  width: 90%;
  margin: 10px;
`;

const Button = styled.TouchableOpacity`
  background-color: ${props => props.theme.colors.primary};
  padding: 12px;
  border-radius: 8px;
  align-items: center;
  margin-top: 10px;
`;

const ButtonText = styled.Text`
  color: white;
  font-weight: bold;
`;

export default function App() {
  return (
    <ThemeProvider theme={theme}>
      <SafeAreaView style={{ flex: 1, justifyContent: 'center', alignItems: 'center' }}>
        <Card $spacing="32px">
          <Typography.H1>Título H1</Typography.H1>
          <Typography.Body>Este card usa Styled Components e consome o ThemeProvider.</Typography.Body>
          <Button>
            <ButtonText>Styled Button</ButtonText>
          </Button>
        </Card>
      </SafeAreaView>
    </ThemeProvider>
  );
}

import { SafeAreaView } from 'react-native';
